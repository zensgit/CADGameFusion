{
  "name": "cadgf-web-viewer-desktop",
  "version": "0.1.0",
  "description": "Desktop wrapper for VemCAD Web Viewer",
  "author": "VemCAD",
  "main": "main.js",
  "private": true,
  "scripts": {
    "clean-pack-output": "node scripts/clean_pack_output.mjs",
    "stage-cad-resources": "node scripts/stage_bundled_cad_resources.mjs",
    "start": "electron .",
    "pack": "npm run stage-cad-resources && npm run clean-pack-output && electron-builder --dir",
    "dist": "npm run stage-cad-resources && npm run clean-pack-output && electron-builder"
  },
  "build": {
    "appId": "com.vemcad.viewer",
    "productName": "VemCAD",
    "icon": "assets/icon",
    "directories": {
      "output": "dist"
    },
    "asar": true,
    "files": [
      "**/*"
    ],
    "fileAssociations": [
      {
        "ext": [
          "dwg",
          "dxf",
          "cad"
        ],
        "name": "VemCAD CAD Drawing",
        "role": "Viewer",
        "rank": "Default"
      }
    ],
    "extraResources": [
      {
        "from": "../web_viewer",
        "to": "web_viewer"
      },
      {
        "from": "bundled_resources",
        "to": "cad_resources"
      }
    ]
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  }
}
